{
  "name": "mcp-server-filemaker",
  "version": "1.1.0",
  "description": "MCP server for FileMaker databases via OData v4 and Data API — works with any MCP client, on-premise, no cloud dependency",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsx watch src/index.ts"
  },
  "keywords": [
    "mcp",
    "filemaker",
    "odata",
    "claude",
    "model-context-protocol",
    "filemakerserver",
    "on-premise"
  ],
  "author": "jk-solution (Joerg Koester)",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
